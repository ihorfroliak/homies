# Copy to .env for local overrides. NEVER commit real secrets.
# SEC-02: outside local/test/ci the app REFUSES to start unless JWT_SECRET and
# WEBHOOK_SECRET are real (not these defaults, >= 32 / 16 chars).
ENV=local

# SEC-01 perimeter rate limiting.
RATE_LIMIT_ENABLED=true
# Number of trusted reverse proxies in front of the app. 0 => X-Forwarded-For is
# NOT trusted (socket peer is used). Raise only if that many trusted proxies
# really terminate in front, otherwise clients can spoof their identity.
TRUST_PROXY_HOPS=0
DATABASE_URL=postgresql+psycopg://homies:homies@localhost:5433/homies
JWT_SECRET=change-me-in-any-shared-environment
ACCESS_TOKEN_TTL_SECONDS=1800
REFRESH_TOKEN_TTL_DAYS=30
PLATFORM_FEE_BPS=1500
DEFAULT_CURRENCY=PLN

# Payments (B1). Default simulation needs no Stripe account.
# For real money set PAYMENT_PROVIDER=stripe and supply TEST keys first.
PAYMENT_PROVIDER=simulation
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
