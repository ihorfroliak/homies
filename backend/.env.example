# Copy to .env for local overrides. NEVER commit real secrets.
ENV=local
DATABASE_URL=postgresql+psycopg://homies:homies@localhost:5433/homies
JWT_SECRET=change-me-in-any-shared-environment
ACCESS_TOKEN_TTL_SECONDS=1800
REFRESH_TOKEN_TTL_DAYS=30
PLATFORM_FEE_BPS=1500
DEFAULT_CURRENCY=PLN

# Payments (B1). Default simulation needs no Stripe account.
# For real money set PAYMENT_PROVIDER=stripe and supply TEST keys first.
PAYMENT_PROVIDER=simulation
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
